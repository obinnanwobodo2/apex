# ====================================================
# Apex Visuals — Environment Variables
# Copy this file to .env.local and fill in your values
# ====================================================

# --- Optional Supabase APIs ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- Clerk Auth ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- Paystack ---
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PLAN_STARTER=PLN_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PLAN_GROWTH=PLN_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PLAN_PRO=PLN_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PLAN_CRM=PLN_xxxxxxxxxxxxxxxxxxxx

# --- Realtime (Pusher) ---
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# --- File Storage ---
# Required only when using Vercel Blob uploads
BLOB_READ_WRITE_TOKEN=

# --- Scheduling ---
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/apexvisual/30min

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: additional allowed browser origins for API CORS (comma-separated)
ALLOWED_CORS_ORIGINS=
# Development / preview only: bypass real payment gateway and simulate successful payments.
# Never enable this on production.
ENABLE_TEST_PAYMENTS=false

# --- Database (Prisma + PostgreSQL) ---
# Example (PostgreSQL):
# postgresql://postgres:postgres@localhost:5432/apex_visuals?schema=public
DATABASE_URL=

# --- Security Monitoring ---
# Optional webhook URL for security alerts (rate-limit blocks, failed admin auth, etc.)
SECURITY_ALERT_WEBHOOK_URL=
# Optional dedicated webhook for app/runtime errors (falls back to SECURITY_ALERT_WEBHOOK_URL)
APP_ALERT_WEBHOOK_URL=

# --- Domain Registrar Integration ---
# Availability endpoint (recommended for accurate checks)
# Example: https://api.your-registrar.com/domains/check?domain={domain}
DOMAIN_PROVIDER_CHECK_URL=
DOMAIN_PROVIDER_CHECK_METHOD=GET

# Registration endpoint (required for direct paid registration)
# Example: https://api.your-registrar.com/domains/register
DOMAIN_PROVIDER_REGISTER_URL=
DOMAIN_PROVIDER_REGISTER_METHOD=POST

# Shared API key/token for registrar endpoints
DOMAIN_PROVIDER_API_KEY=

# --- Admin Access Control ---
# Single-owner mode: set OWNER_USER_ID (or OWNER_EMAIL) so only one account can access /admin
OWNER_USER_ID=
OWNER_EMAIL=

# Legacy fallback (optional): first value only is used as the owner account
ADMIN_EMAILS=
ADMIN_USER_IDS=

# Extra gate for /admin and /api/admin (HTTP Basic auth)
ADMIN_BASIC_USERNAME=
ADMIN_BASIC_PASSWORD=

# No dev fallback is used for admin authorization. Keep this false.
ALLOW_ADMIN_DEV_FALLBACK=false

# --- Termly (Legal Embeds) ---
NEXT_PUBLIC_TERMLY_PRIVACY_POLICY_ID=
NEXT_PUBLIC_TERMLY_TERMS_OF_USE_ID=
