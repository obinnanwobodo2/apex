# ====================================================
# Apex Visuals — Environment Variables
# Copy this file to .env.local and fill in your values
# ====================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- Clerk Auth ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- Paystack ---
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (Prisma + PostgreSQL) ---
# Example (Supabase): postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# Example (Neon): postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL=

# --- Security Monitoring ---
# Optional webhook URL for security alerts (rate-limit blocks, failed admin auth, etc.)
SECURITY_ALERT_WEBHOOK_URL=

# --- Domain Registrar Integration ---
# Availability endpoint (recommended for accurate checks)
# Example: https://api.your-registrar.com/domains/check?domain={domain}
DOMAIN_PROVIDER_CHECK_URL=
DOMAIN_PROVIDER_CHECK_METHOD=GET

# Registration endpoint (required for direct paid registration)
# Example: https://api.your-registrar.com/domains/register
DOMAIN_PROVIDER_REGISTER_URL=
DOMAIN_PROVIDER_REGISTER_METHOD=POST

# Shared API key/token for registrar endpoints
DOMAIN_PROVIDER_API_KEY=

# --- Admin Access Control ---
# Clerk email(s) and/or user id(s) allowed to access /admin
ADMIN_EMAILS=
ADMIN_USER_IDS=

# Extra gate for /admin and /api/admin (HTTP Basic auth)
ADMIN_BASIC_USERNAME=
ADMIN_BASIC_PASSWORD=

# Keep this false in production
ALLOW_ADMIN_DEV_FALLBACK=false
